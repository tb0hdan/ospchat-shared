root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{kt,kts}]
# Jetpack Compose @Composable functions are conventionally PascalCase, so we
# silence ktlint's standard function-naming rule for Kotlin sources.
ktlint_standard_function-naming = disabled

[*.{yml,yaml}]
indent_size = 2
